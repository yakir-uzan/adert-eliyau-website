# Example .env for local development - do NOT commit real secrets to VCS

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
VITE_PUBLIC_SITE_URL=https://your-domain.com
VITE_PLATFORM_ADMIN_EMAILS=you@example.com
VITE_ENABLE_AUTOMATIC_CHECKOUT=true
VITE_SITE_ACTIVATION_PAYMENT_LINK=https://your-payment-link.example
VITE_STRIPE_PUBLIC_KEY=pk_test_your_publishable_key
VITE_PUBLIC_CONTACT_WHATSAPP=https://wa.me/972000000000
VITE_PUBLIC_CONTACT_EMAIL=info@example.com
VITE_PUBLIC_CONTACT_FORMSPREE_ID=your_formspree_id
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key
APP_BASE_URL=https://your-domain.com
DEFAULT_SETUP_AMOUNT_ILS=490

# Secrets are configured with Firebase Secret Manager, not here:
# firebase functions:secrets:set STRIPE_SECRET_KEY
# firebase functions:secrets:set STRIPE_WEBHOOK_SECRET

# Stripe webhook events required:
# - checkout.session.completed
# - checkout.session.expired
# - payment_intent.succeeded
